{
  "manifest_version": 3,
  "name": "API Spending Monitor",
  "version": "0.1.0",
  "description": "Real-time AI API spending tracker for Anthropic, OpenAI, and more",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.frankfurter.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "assets/claude-toad-square.png",
      "48": "assets/claude-toad-square.png",
      "128": "assets/claude-toad-square.png"
    }
  },
  "icons": {
    "16": "assets/claude-toad-square.png",
    "48": "assets/claude-toad-square.png",
    "128": "assets/claude-toad-square.png"
  },
  "options_page": "settings.html",
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
